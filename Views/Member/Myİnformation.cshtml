@model List<Appointment>

@{
    ViewData["Title"] = "My Appointments";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-10">
        <div class="p-4 bg-light rounded shadow-sm">
            <h3 class="h4 mb-4 pb-2 border-bottom text-primary">📋 My Upcoming Appointments</h3>

            @if (Model != null && Model.Any())
            {
                <div class="d-none d-md-block bg-white rounded-top fw-bold text-muted p-2 border-bottom">
                    <div class="d-flex w-100 justify-content-start align-items-center gap-4">
                        <span style="width: 120px;">Date</span>
                        <span style="width: 70px;">Time</span>
                        <span style="width: 120px;">Coach</span>
                        <span class="ms-auto" style="width: 80px;">Cancel</span>
                    </div>
                </div>

                <div class="list-group">
                    @foreach (var appointment in Model)
                    {
                        <div class="list-group-item list-group-item-action mb-2 rounded shadow-sm">
                            <div class="d-flex w-100 justify-content-between align-items-center flex-wrap">
                                <div class="d-flex flex-wrap gap-4 align-items-center">
                                    <span class="text-dark fw-bold" style="width: 120px;">
                                        📅 @appointment.Date.ToString("dd MMM yyyy")
                                    </span>
                                    <span class="text-secondary" style="width: 70px;">
                                        ⏰ @appointment.Time.ToString(@"hh\:mm")
                                    </span>

                                    <span class="badge bg-success text-white">
                                        👤 @appointment.Coach.member.UserName
                                    </span>
                                </div>

                                <form method="post" asp-action="CancelAppointment" class="ms-auto"
                                      onsubmit="return confirm('Are you sure you want to cancel this appointment on @appointment.Date.ToString("dd.MM.yyyy")?');">
                                    <input type="hidden" name="id" value="@appointment.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        ❌ Cancel
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info text-center py-4 border-0 shadow-sm" role="alert">
                    <div class="h3 no-appointments-icon mb-3">📭</div>
                    <h4 class="alert-heading">No Upcoming Appointments</h4>
                    <p class="mb-0 text-muted">You don't have any scheduled sessions yet.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}