@model IEnumerable<Member>

<h3>@TempData["Mesaj"]</h3>
<h2>Member List</h2>
<table class="table">
    <thead>
        <tr>
            <th>Email</th>
            <th>Username</th>
            <th>Weight</th>
            <th>Length</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var member in Model)
        {
            <tr>
                <td>@member.Email</td>
                <td>@member.UserName</td>
                <td>@member.weight</td>
                <td>@member.length</td>
                <td>
                    <a asp-action="DeleteMember" asp-route-id="@member.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>