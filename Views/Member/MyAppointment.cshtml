@model List<Appointment>
@{
    ViewData["Title"] = "My Appointments";
    //  onsubmit="return confirm('Are you sure you want to cancel this appointment on @appointment.Date.ToString("dd.MM.yyyy")?');"
    // from kısımnda gerekli olursa ekle
}

@section Styles {
    <style>
        .appointments-container h3 {
            color: #333 ;
            font-size: 1.5rem;
            font-weight: normal ;
        }

        .list-group-item {
            margin-bottom: 20px;
        }

        .appointment-info span {
            margin-right: 30px;
        }

       
    </style>
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-10">
        <div class="p-4 bg-light rounded shadow-sm">
            <h3 class="h4 mb-4 pb-2 border-bottom">My Upcoming Appointments</h3>
            @if (TempData["Msj"] != null)
            {
                <p>@TempData["Msj"]</p>
            }
            @if (Model != null && Model.Any())
            {
                <div class="d-none d-md-block bg-white rounded-top fw-bold text-muted p-2 border-bottom">
                    <div class="d-flex w-100 justify-content-start align-items-center gap-4">
                        <span style="width: 160px;">Date</span>
                        <span style="width: 160px;">Time</span>
                        <span style="width: 160px;">Coach</span>
                        <span style="width: 160px;">Status</span>
                        <span class="ms-auto" style="width: 80px;">Cancel</span>
                    </div>
                </div>
                <div class="list-group">
                    @foreach (var appointment in Model)
                    {
                        <div class="list-group-item list-group-item-action mb-2 rounded shadow-sm">
                            <div class="d-flex w-100 justify-content-between align-items-center flex-wrap">
                                <div class="d-flex flex-wrap gap-4 align-items-center appointment-info">
                                    <span class="text-dark fw-bold" style="width: 125px;">
                                        @appointment.Date.ToString("dd MMM yyyy", new System.Globalization.CultureInfo("en-US"))
                                    </span>
                                    <span class="text-secondary" style="width: 130px;">
                                        @appointment.Time.ToString(@"hh\:mm")
                                    </span>
                                    <span class="text-dark fw-bold" style="width: 130px;">
                                        @appointment.Coach.member.UserName
                                    </span>
                                    <span class="text-dark fw-bold" style="width: 140px;">
                                        @if(appointment.IsConfirmed)
                                        {
                                            <span class="text-success">Confirmed</span>
                                        }
                                        else
                                        {
                                            <span class="text-warning">Pending</span>
                                        }
                                    </span>
                                </div>
                                <form method="post" asp-action="CancelAppointment" class="ms-auto" >
                                    
                                    <input type="hidden" name="id" value="@appointment.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        Cancel
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info text-center py-4 border-0 shadow-sm"
                     style="background-color:#f3e5d8; color:#5a3e2b;">
                    <h4 >No Upcoming Appointments</h4>
                   
                </div>
            }
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}