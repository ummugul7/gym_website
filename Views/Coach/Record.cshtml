@model proje.Models.CoachViewModel


@{
    ViewData["Title"] = "Record";
}

<div class="d-flex justify-content-center align-items-center min-vh-100">
    <div class="card shadow-sm border-0 rounded-4 p-4" style="width: 420px;">

        <h3 class="text-center fw-semibold mb-3">
            Coach Register
        </h3>
        <hr />

        <form asp-action="Record" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            

            <div class="mb-3">
                <label asp-for="UserName" class="form-label small fw-semibold"></label>
                <input asp-for="UserName" class="form-control form-control-sm" />
                <span asp-validation-for="UserName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label small fw-semibold"></label>
                <input asp-for="Email" class="form-control form-control-sm" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label small fw-semibold"></label>
                <input asp-for="Password" type="password" class="form-control form-control-sm" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="speciality" class="form-label small fw-semibold"></label>
                <input asp-for="speciality" class="form-control form-control-sm" />
                <span asp-validation-for="speciality" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="experience" class="form-label small fw-semibold"></label>
                <input asp-for="experience" class="form-control form-control-sm" />
                <span asp-validation-for="experience" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="price" class="form-label small fw-semibold"></label>
                <input asp-for="price" class="form-control form-control-sm" />
                <span asp-validation-for="price" class="text-danger small"></span>
            </div>
            <div class="text-center">
                <input type="submit" value="Save" class="btn btn-primary px-5" />
            </div>
        </form>

    </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}



              

