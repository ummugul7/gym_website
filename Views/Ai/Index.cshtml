@model proje.Models.AiViewModel

@{
    ViewData["Title"] = "AI Personal Trainer";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center align-items-center">
        <div class="card shadow-sm border-0 rounded-4 p-4" style="width: 100%; max-width: 550px;">

            <h3 class="text-center fw-bold mb-3 text-dark">
                <i class="bi bi-cpu"></i> AI Fitness Assistant
            </h3>
            <p class="text-center text-muted small">Enter your details to generate a custom fitness and diet plan.</p>
            <hr />

            <form asp-action="GetSuggestion" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Age" class="form-label small fw-semibold">Age</label>
                        <input asp-for="Age" type="number" class="form-control form-control-sm" placeholder="e.g. 25" required />
                        <span asp-validation-for="Age" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Height" class="form-label small fw-semibold">Height (cm)</label>
                        <input asp-for="Height" type="number" class="form-control form-control-sm" placeholder="e.g. 180" required />
                        <span asp-validation-for="Height" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Weight" class="form-label small fw-semibold">Weight (kg)</label>
                        <input asp-for="Weight" type="number" class="form-control form-control-sm" placeholder="e.g. 75" required />
                        <span asp-validation-for="Weight" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Gender" class="form-label small fw-semibold">Gender</label>
                        <select asp-for="Gender" class="form-select form-select-sm">
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger small"></span>
                    </div>
                </div>

                <div class="text-center mt-3">
                    <button type="submit" id="btnSubmit" class="btn btn-primary px-5 w-100 fw-bold shadow-sm">
                        Generate My Program
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (ViewBag.AiResponse != null)
    {
        <div class="row justify-content-center mt-4">
            <div class="col-md-10 col-lg-8 card shadow-lg border-0 rounded-4 p-4" style="background-color: #ffffff;">
                <h4 class="text-dark fw-bold border-bottom pb-3 mb-3">
                    <i class="bi bi-stars text-warning"></i> Your Personalized Plan
                </h4>
                <div class="mt-2 ai-content" style="line-height: 1.7; color: #333;">
                    @Html.Raw(ViewBag.AiResponse)
                </div>
                <div class="text-center mt-4">
                    <button class="btn btn-outline-secondary btn-sm" onclick="window.print()">
                        <i class="bi bi-printer"></i> Print Plan
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}