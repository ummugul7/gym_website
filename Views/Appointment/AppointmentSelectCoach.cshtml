@model IEnumerable<Coach>

@{
    ViewData["Title"] = "Select Your Coach";
}

@section Styles {
    <style>
        .coach-container {
            max-width: 700px;
            margin: 50px auto;
            padding: 20px;
        }

            .coach-container h2 {
                margin-bottom: 30px;
            }

        .coach-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 15px;
        }

            .coach-table th {
                text-align: left;
                padding-bottom: 10px;
                border-bottom: 2px solid #ddd;
            }

            .coach-table td {
                padding: 15px 10px;
                background: #f8f9fa;
            }

            .coach-table tr td:first-child {
                border-radius: 4px 0 0 4px;
            }

            .coach-table tr td:last-child {
                border-radius: 0 4px 4px 0;
            }

        .btn-select {
            background: #007bff;
            color: white;
            padding: 8px 25px;
            text-decoration: none;
            border-radius: 4px;
            display: inline-block;
        }

            .btn-select:hover {
                background: #0056b3;
                color: white;
            }
    </style>
}

<div class="coach-container">
    <h2>Select Your Coach</h2>

    @if (TempData["Mesaj"] != null)
    {
        <p>@TempData["Mesaj"]</p>
    }

    <table class="coach-table">
        <thead>
            <tr>
                <th>Username</th>
                <th>Speciality</th>
                <th>Price</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var coach in Model)
            {
                <tr>
                    <td>@coach.member.UserName</td>
                    <td>@coach.speciality</td>
                    <td>$@coach.price</td>
                    <td>
                        <a asp-action="AppointmentList" asp-route-id="@coach.Id" class="btn-select">
                            Select
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>