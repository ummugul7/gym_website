@model IEnumerable<proje.Models.AppointmentGroupVM>

@{
    ViewData["Title"] = "Available Appointments";
}

<style>
    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-size: 15px;
    }

    .card {
        border: 1px solid #e0e0e0;
        border-radius: 4px;
    }

    .card-header {
        background-color: #583a0e;
        color: white;
        padding: 12px 16px;
        border-radius: 4px 4px 0 0;
        font-size: 14px;
        font-weight: 500;
    }

    .card-body {
        padding: 20px;
    }

    .appointment-time-btn {
        font-size: 10px;
        padding: 6px 14px;
        border: 1px solid #d0d0d0;
        background-color: white;
        color: #333;
        border-radius: 3px;
        transition: all 0.2s ease;
        margin: 4px;
    }

        .appointment-time-btn:hover {
            background-color: #e3f2fd;
            border-color: #90caf9;
            color: #1976d2;
        }

    .btn-confirm {
        background-color: #1976d2;
        color: white;
        border: none;
        padding: 10px;
        font-size: 13px;
        font-weight: 500;
        border-radius: 3px;
        transition: background-color 0.2s ease;
    }

        .btn-confirm:hover:not(:disabled) {
            background-color: #1565c0;
        }

        .btn-confirm:disabled {
            background-color: #e0e0e0;
            color: #9e9e9e;
            cursor: not-allowed;
        }

    .btn-selected {
        background-color: #76622d ;
        color: white !important;
        border-color: #76622d;
        font-weight: 500;
    }

    .page-title {
        font-size: 22px;
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
    }

    .page-subtitle {
        font-size: 14px;
        color: #666;
        margin-bottom: 30px;
    }

    .no-times-text {
        color: #999;
        font-size: 13px;
        font-style: italic;
    }

    .alert {
        font-size: 14px;
        border-radius: 4px;
    }
</style>

<div class="container my-5">
  
    <h1 class="page-title text-center">Available Appointments</h1>
  <hr />
    @if (TempData["Msjbook"] != null)
    {
        <p>@TempData["Msjbook"]</p>
    }

    @if (Model != null && Model.Any())
    {
        <div class="row justify-content-center">
            <div class="row">
                @foreach (var day in Model.OrderBy(d => d.Date))
                {
                    <div class="col-md-6 mb-4">
                        <div class="card" data-card-id="@day.Date.Date.Ticks">
                            <div class="card-header">
                                @day.Date.ToString("MMMM dd, yyyy - dddd", new System.Globalization.CultureInfo("en-US")) 
                            </div>
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex flex-wrap align-items-center mb-3">
                                    @if (day.Times.Any())
                                    {
                                        @foreach (var t in day.Times.OrderBy(t => t.Time))
                                        {
                                            <button type="button"
                                                    data-appointment-id="@t.AppointmentId"
                                                    data-card-id="@day.Date.Date.Ticks"
                                                    class="btn btn-outline-success btn-sm m-1 appointment-time-btn">
                                                @t.Time.ToString(@"hh\:mm")
                                            </button>
                                        }
                                    }
                                    else
                                    {
                                        <p class="no-times-text">No available times</p>
                                    }
                                </div>

                                <form id="form-@day.Date.Date.Ticks" asp-action="AppointmentBook" method="get" class="mt-auto">
                                    <input type="hidden" name="id" id="selected-id-@day.Date.Date.Ticks" value="" />
                                    <button type="submit"
                                            id="btn-confirm-@day.Date.Date.Ticks"
                                            class="btn-confirm w-100"
                                            disabled>
                                        CONFIRM APPOINTMENT
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const timeButtons = document.querySelectorAll('.appointment-time-btn');

            timeButtons.forEach(button => {
                button.addEventListener('click', function () {
                    const cardId = this.dataset.cardId;
                    const appointmentId = this.dataset.appointmentId;
                    const confirmButton = document.getElementById(`btn-confirm-${cardId}`);
                    const selectedIdInput = document.getElementById(`selected-id-${cardId}`);

                    const allButtonsInCard = document.querySelectorAll(`.appointment-time-btn[data-card-id="${cardId}"]`);
                    allButtonsInCard.forEach(btn => btn.classList.remove('btn-selected'));

                    this.classList.add('btn-selected');

                    // Form alanını ve onay butonunu güncelle
                    selectedIdInput.value = appointmentId;
                    confirmButton.disabled = false;
                });
            });
        });
    </script>
}